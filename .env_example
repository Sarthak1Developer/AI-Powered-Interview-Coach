FLASK_SECRET_KEY=your_api_key_here
API_KEY=your_api_key_here
# Optional judge-style injected key name (used if API_KEY is missing)
JUDGE_API_KEY=your_judge_api_key_here
API_BASE_URL=your_api_base_url
FREEPIK_API_KEY=your_api_key_here
HF_TOKEN=your_huggingface_token_here
MODEL_NAME=gpt-4o-mini
OPENAI_KEY_BACKUP=your_backup_openai_key_here

# Local/remote model settings
INTERVIEW_COACH_ENABLE_LOCAL_MODELS=1
INTERVIEW_COACH_MODELS_DIR=/app/interview_coach_models
INTERVIEW_COACH_GRADE_SOURCE=local_ml
INTERVIEW_COACH_APPEND_LOCAL_ML_FEEDBACK=1

# Auto-download T5 model files if local weights are missing
INTERVIEW_COACH_AUTO_DOWNLOAD_T5=1
INTERVIEW_COACH_T5_REPO_ID=Shauriya24/AI-Powered-Interview-Coach
INTERVIEW_COACH_T5_REPO_TYPE=space
INTERVIEW_COACH_T5_SUBFOLDER=interview_coach_models/t5_interview_coach
INTERVIEW_COACH_HF_CACHE_DIR=/app/interview_coach_models/hf_cache

# If Spaces rejects long key names, you can use these short aliases instead:
# AUTO_DOWNLOAD_T5=1
# T5_REPO_ID=Shauriya24/AI-Powered-Interview-Coach
# T5_REPO_TYPE=space
# T5_SUBFOLDER=interview_coach_models/t5_interview_coach
# HF_CACHE_DIR=/app/interview_coach_models/hf_cache
